ENVIRONMENT=development
DEBUG=true
PROJECT_NAME=Customer Retention & Sales Automation API
PROJECT_DESCRIPTION=Phase 1 backend for authentication, customer management, and sales workflows.
PROJECT_VERSION=1.0.0
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=customer_sales

JWT_SECRET_KEY=change-me-in-production
JWT_REFRESH_SECRET_KEY=change-me-refresh-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

PASSWORD_BCRYPT_ROUNDS=12
LOG_LEVEL=INFO
