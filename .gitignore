cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
.venv/
env/

# Environment Variables
.env
.env.*
!.env.example

# Python Build
build/
dist/
*.egg-info/
.eggs/

# Cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/

# Logs
logs/
*.log

# Node / Next.js
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/.vercel/

# Docker Data
docker-data/
postgres-data/

# Database
*.db
*.sqlite
*.sqlite3

# Redis
dump.rdb

# OS Files
.DS_Store
Thumbs.db
EOF